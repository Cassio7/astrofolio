---
import { SOCIAL_LINKS } from "@/lib/constants";
---

<footer class="w-full border-t border-dashed md:border-b">
  <div
    class="mx-auto flex max-w-3xl flex-col-reverse items-center justify-between gap-4 border-dashed px-4 py-3 md:border-x lg:flex-row"
  >
    <p class="text-sm text-foreground/70">
      Built by <a href="https://github.com/Cassio7" class="font-medium text-primary underline underline-offset-4"
        >Cassio</a
      >
      <span class="mx-2 text-foreground/40">•</span>
      <a href="/privacy" class="text-sm text-foreground/70 underline underline-offset-4 hover:text-primary">Privacy</a>
      <span class="mx-1 text-foreground/40">•</span>
      <a href="/terms" class="text-sm text-foreground/70 underline underline-offset-4 hover:text-primary">Terms</a>
    </p>

    <div class="flex items-center justify-center gap-4">
      {
        SOCIAL_LINKS.map(link => (
          <a href={link.url} aria-label={link.name}>
            <link.icon className="size-4 duration-150 hover:text-primary" />
          </a>
        ))
      }
    </div>
  </div>
</footer>
